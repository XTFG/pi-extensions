{
	"name": "@narumitw/pi-skillforge",
	"version": "0.2.1",
	"description": "Pi package for improving agent skills through verified project memory.",
	"type": "module",
	"license": "MIT",
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/narumiruna/pi-skillforge.git",
		"directory": "extensions/pi-skillforge"
	},
	"bugs": {
		"url": "https://github.com/narumiruna/pi-skillforge/issues"
	},
	"homepage": "https://github.com/narumiruna/pi-skillforge/tree/main/extensions/pi-skillforge#readme",
	"keywords": [
		"pi-package",
		"pi",
		"pi-coding-agent",
		"extension",
		"skills",
		"memory"
	],
	"files": [
		"src",
		"lib",
		"schemas",
		"templates",
		"examples",
		"README.md",
		"PLAN.md",
		"LICENSE"
	],
	"peerDependencies": {
		"typebox": "*"
	},
	"pi": {
		"extensions": [
			"./src/skillforge.ts"
		]
	},
	"scripts": {
		"check": "biome check . && npm run typecheck",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@mariozechner/pi-coding-agent": "^0.72.1",
		"@types/node": "^25.6.0",
		"typebox": "^1.1.37",
		"typescript": "^6.0.3"
	}
}
