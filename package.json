{
	"name": "pi-extensions",
	"version": "0.0.0",
	"private": true,
	"description": "Monorepo for @narumitw pi extension packages.",
	"type": "module",
	"workspaces": [
		"extensions/*"
	],
	"scripts": {
		"format": "biome format --write .",
		"lint": "biome lint .",
		"biome:check": "biome check .",
		"typecheck": "npm --workspaces run typecheck",
		"check": "npm run biome:check && npm run typecheck",
		"pack:skillforge": "npm --workspace @narumitw/pi-skillforge pack --dry-run",
		"pack:retry": "npm --workspace @narumitw/pi-retry pack --dry-run"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@mariozechner/pi-coding-agent": "^0.72.1",
		"@types/node": "^25.6.0",
		"typebox": "^1.1.37",
		"typescript": "^6.0.3"
	}
}
